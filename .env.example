# 复制为 .env 后填入真实值。.env 已被 .gitignore 忽略,切勿提交。
# 生产(Render)不读本文件:请在 Render 后台 Environment 里逐项配置。

PORT=3001
NODE_ENV=production

# ---------- MongoDB ----------
# 生产:Atlas 连接串   mongodb+srv://user:pass@cluster/db
# 本地 docker compose --profile dev up:mongodb://mongo:27017/juxin
MONGODB_URI=mongodb://mongo:27017/juxin

# ---------- 管理员认证(JWT)----------
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=            # bcrypt 哈希(推荐)
# ADMIN_PASSWORD=              # 明文回退(仅开发)
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# ---------- 邮件(Resend 主 / SMTP 兜底)----------
RESEND_API_KEY=re_xxx
MAIL_FROM=onboarding@resend.dev
MAIL_TO=your-inbox@example.com
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=xxx@qq.com
SMTP_PASS=your_smtp_app_password

# ---------- 对象存储(阿里云 OSS,S3 兼容)----------
OSS_REGION=cn-hangzhou
OSS_BUCKET=your-bucket
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
OSS_PUBLIC_BASE_URL=https://img.your-domain.com
OSS_ACCESS_KEY_ID=your-oss-key-id
OSS_ACCESS_KEY_SECRET=your-oss-key-secret

# ---------- 日志 ----------
LOG_LEVEL=info

# ---------- LLM (OpenAI 兼容, 可切换) ----------
# 用 OpenAI 兼容 SDK, 换 provider 只改这三行, 代码不动.
#
# Groq (Llama 70B, 免费额度):
#   LLM_BASE_URL=https://api.groq.com/openai/v1
#   LLM_MODEL=llama-3.3-70b-versatile
#
# Gemini (免费额度): 注意 ① 模型会到期 → 用 -latest 别名 ② 免费档按天限量
#   LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
#   LLM_MODEL=gemini-flash-lite-latest   # lite 免费日额度更宽; 高级版 gemini-3.5-flash 仅 20 次/天
#
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=                    # provider 控制台申请
LLM_MODEL=llama-3.3-70b-versatile
